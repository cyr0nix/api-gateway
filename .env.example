PORT=3000
NODE_ENV=development

# CORS - comma separated origins, or "*" for all (not allowed in production)
CORS_ORIGINS=*

# Redis - mode: standalone | sentinel | cluster
REDIS_MODE=standalone
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# for sentinel/cluster mode: host:port,host:port
REDIS_NODES=
REDIS_SENTINEL_NAME=mymaster

# JWT - REQUIRED in production, must be 32+ chars
JWT_SECRET=your-super-secret-key-change-this-to-32-chars-min
JWT_EXPIRES_IN=7d

# Rate Limiting - fail mode: open (allow on redis outage) | closed (block)
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100
RATE_LIMIT_FAIL_MODE=open

# Cache TTL (seconds)
CACHE_TTL=300

# Proxy resilience
PROXY_TIMEOUT=30000
PROXY_RETRIES=1

# Circuit breaker
CB_ERROR_THRESHOLD=50
CB_RESET_TIMEOUT=15000

# Upstream Services - each can list multiple replicas, comma separated
# e.g. http://users-1:4001,http://users-2:4001
USER_SERVICE_URL=http://localhost:4001
ORDER_SERVICE_URL=http://localhost:4002
PRODUCT_SERVICE_URL=http://localhost:4003

# Graceful shutdown drain deadline (ms)
SHUTDOWN_TIMEOUT=10000

# Log level override (trace|debug|info|warn|error|silent)
# LOG_LEVEL=info
